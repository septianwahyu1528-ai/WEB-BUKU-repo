{
  "name": "toko-buku",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "node run.js",
    "dev:concurrent": "concurrently --kill-others \"node server/index.js\" \"vite\" --names \"Backend,Frontend\"",
    "dev:watch": "concurrently \"npm run server:dev\" \"vite\"",
    "server": "node server/index.js",
    "server:dev": "nodemon --inspect=9229 server/index.js",
    "build": "tsc -b && vite build",
    "setup-db": "node setup-database.js",
    "db:setup": "psql -h localhost -U postgres -f database_complete_setup.sql",
    "db:migrate": "node server/database/add-image-column.js",
    "vercel-build": "vite build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.0",
    "axios": "^1.6.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.18.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.1",
    "typescript": "^5.2.2",
    "vite": "^5.0.0"
  },
  "server-dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "pg": "^8.11.0",
    "jsonwebtoken": "^9.1.0",
    "dotenv": "^16.3.1",
    "nodemon": "^3.0.1"
  }
}
